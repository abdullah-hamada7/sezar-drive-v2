# Fleet Management API — example environment variables
# Copy to .env and set values. Never commit .env to version control.

# Required in production
JWT_SECRET=your-minimum-32-character-secret-here-change-in-production

# Prisma/Postgres
# - Add connection_limit to avoid exhausting Postgres connections under load.
# - Add pool_timeout to fail fast when the DB is saturated.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/sezar_drive?schema=public&connection_limit=10&pool_timeout=10

# Production: set explicit origin(s). Comma-separated for multiple.
CORS_ORIGIN=https://your-frontend-domain.com

# Optional
PORT=3000
NODE_ENV=development
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
UPLOAD_DIR=./uploads

# Firebase Cloud Messaging (mobile push) — optional; web-push still works without these
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# AWS S3 Storage — optional; local filesystem storage used if omitted
# S3_BUCKET=your-s3-bucket-name
# S3_REGION=us-east-1

# VAPID Web Push Keys — optional; uses default keys if omitted
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# Additional configurations
# FRONTEND_URL=http://localhost:5173
# TRUST_PROXY=true

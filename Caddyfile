{
    email {$EMAIL_FOR_SSL}
}

{$DOMAIN_NAME} {
    # ─── Backend API ───
    handle /api/* {
        reverse_proxy backend:3000
    }

    # ─── Tracking WebSockets ───
    handle /ws/* {
        reverse_proxy backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # ─── Frontend (Catch-all) ───
    handle {
        reverse_proxy frontend:80
    }

    # Optional: Gzip compression
    encode gzip
}
